{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled dental consultation",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "status": { "type": "string", "enum": ["pendiente", "confirmed", "in-session", "finished", "cancelled"] },
        "type": { "type": "string" },
        "attendance": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "patientName", "date", "time", "status", "type"]
    },
    "Patient": {
      "title": "Patient",
      "description": "A patient record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "idNumber": { "type": "string" },
        "gender": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "lastVisit": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "idNumber", "status"]
    },
    "Evolution": {
      "title": "Evolution",
      "description": "A clinical evolution entry for a patient",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "doctor": { "type": "string" },
        "note": { "type": "string" },
        "treatment": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "date", "doctor", "note"]
    },
    "Treatment": {
      "title": "Treatment",
      "description": "A dental procedure or treatment offered",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "duration": { "type": "number" },
        "cost": { "type": "number" },
        "materials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "materialId": { "type": "string" },
              "qty": { "type": "number" }
            }
          }
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "cost"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Stock item in the clinic",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["normal", "low", "out"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "stock", "minStock", "price"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Settings for the clinician",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "specialty": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "primaryColor": { "type": "string" },
        "darkMode": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "schedule": {
          "type": "object",
          "properties": {
            "morningStart": { "type": "string" },
            "morningEnd": { "type": "string" },
            "morningActive": { "type": "boolean" },
            "afternoonStart": { "type": "string" },
            "afternoonEnd": { "type": "string" },
            "afternoonActive": { "type": "boolean" },
            "workingDays": { "type": "array", "items": { "type": "number" } }
          }
        }
      },
      "required": ["email", "name"]
    },
    "ReminderSettings": {
      "title": "Reminder Settings",
      "description": "WhatsApp reminder message templates and bot configurations",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "template": { "type": "string" },
        "botEnabled": { "type": "boolean" },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "active": { "type": "boolean" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "template"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Secretary or administrative staff registered by the professional",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Professional", "Secretary", "Admin"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Activo", "Inactivo"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "status", "userId"]
    },
    "WhatsAppLog": {
      "title": "WhatsApp Log",
      "description": "Log of messages sent via WhatsApp",
      "type": "object",
      "properties": {
        "to": { "type": "string" },
        "patientName": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "error"] },
        "error": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["to", "message", "status", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/appointments": {
      "schema": "Appointment",
      "description": "Collection of all dental appointments"
    },
    "/patients": {
      "schema": "Patient",
      "description": "Collection of patient records"
    },
    "/patients/{patientId}/evolutions": {
      "schema": "Evolution",
      "description": "History of evolutions for a patient"
    },
    "/treatments": {
      "schema": "Treatment",
      "description": "Collection of available dental treatments"
    },
    "/stocks": {
      "schema": "InventoryItem",
      "description": "Clinic stocks catalog"
    },
    "/users": {
      "schema": "UserProfile",
      "description": "Main professional user data and account settings"
    },
    "/profiles": {
      "schema": "UserProfile",
      "description": "User specific settings and profiles"
    },
    "/reminder_settings": {
      "schema": "ReminderSettings",
      "description": "User settings for WhatsApp reminders"
    },
    "/staff": {
      "schema": "Staff",
      "description": "Staff members associated with the professional"
    },
    "/whatsapp_logs": {
      "schema": "WhatsAppLog",
      "description": "History of WhatsApp reminders sent"
    }
  }
}
